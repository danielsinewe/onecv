    "url": "https://github.com/danielsinewe/onecv/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "playwright": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2"
  }
